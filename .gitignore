.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
build/
dist/
pip-wheel-metadata/

# --- Datos crudos y procesados (NO se versionan) ---
data/raw/
data/processed/
*.fits
*.fits.gz
*.pt
*.pth
*.ckpt
*.npy
*.npz
*.h5
*.hdf5

# Excepción: los splits (TIC IDs train/val/test) SÍ se versionan
!data/splits/
!data/splits/**

# --- Outputs de experimentos ---
experiments/
runs/
wandb/
mlruns/
lightning_logs/
tensorboard/
logs/

# --- Notebooks: guardamos código, no outputs ---
.ipynb_checkpoints/

# --- Caches de herramientas ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- IDE / editores ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Agente (Etapa 3) ---
agent/.env                 # secretos (ANTHROPIC_API_KEY) — NUNCA versionar
agent/_figcache/           # figuras regeneradas por las tools
agent/logs/                # sesiones reales del agente (ya cubierto por logs/, explícito)
# Excepción: los resultados de la suite de validación SÍ se versionan (evidencia paper)
!agent/eval/results/
!agent/eval/results/**
