# Copiá este archivo a agent/.env y completá tu clave para activar el modo Claude.
# Sin esto, el agente corre en modo 'mock' (orquestación determinista, sin costo).
# agent/.env está en .gitignore — NUNCA lo subas al repo.

ANTHROPIC_API_KEY=sk-ant-...

# Opcional: sobrescribir el modelo (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
